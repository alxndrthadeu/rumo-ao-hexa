# Supabase — obter em https://app.supabase.com → Project Settings → API
#
# IMPORTANTE: sem NEXT_PUBLIC_SUPABASE_URL o app usa in-memory store.
# Dados são perdidos ao reiniciar o servidor e bugs do Supabase só aparecem em produção.
# Configure essas variáveis para desenvolvimento com persistência real.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
